{
  "openapi": "3.0.3",
  "info": {
    "title": "HttpBin Live Test API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://httpbin.org"
    }
  ],
  "paths": {
    "/post": {
      "post": {
        "operationId": "postTest",
        "summary": "Test POST endpoint that echoes data",
        "description": "Returns JSON with posted data - always succeeds",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount", "reason"],
                "properties": {
                  "amount": {
                    "type": "number",
                    "example": 100
                  },
                  "reason": {
                    "type": "string",
                    "example": "Customer refund"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success - returns posted data"
          },
          "400": {
            "description": "Bad Request - invalid data"
          }
        }
      }
    },
    "/get": {
      "get": {
        "operationId": "getTest",
        "summary": "Test GET endpoint that echoes query params",
        "description": "Returns query parameters - always succeeds",
        "responses": {
          "200": {
            "description": "Success"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/status/404": {
      "get": {
        "operationId": "getNotFound",
        "summary": "Returns 404 status",
        "responses": {
          "404": {
            "description": "NotFound"
          }
        }
      }
    },
    "/status/500": {
      "get": {
        "operationId": "getError",
        "summary": "Returns 500 status",
        "responses": {
          "500": {
            "description": "Server Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}