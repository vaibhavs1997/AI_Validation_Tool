# Local server
PORT=4173

# Jira Cloud integration
# Example: https://your-company.atlassian.net
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# Optional AI enhancement. The app works without this; it falls back to deterministic local generation.
# Provider-agnostic configuration using AI_* variables (preferred):
# Any OpenAI-compatible API can be used (OpenAI, Groq, Together, etc.)
AI_PROVIDER=openai
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gpt-4.1-mini
AI_BASE_URL=https://api.openai.com/v1

# Alternative: Groq AI (free tier available)
# AI_PROVIDER=groq
# AI_API_KEY=your_groq_api_key_here
# AI_MODEL=llama-3.3-70b-versatile
# AI_BASE_URL=https://api.groq.com/openai/v1

# Alternative: Ollama (local, no API key needed)
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2  # or llama3.1, etc.
# AI_BASE_URL=http://localhost:11434/v1

# Legacy configuration (backward compatible) - still supported
OPENAI_API_KEY=your_ai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# API execution defaults
REQUEST_TIMEOUT_MS=20000