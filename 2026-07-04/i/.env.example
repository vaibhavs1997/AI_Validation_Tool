# Local server
PORT=4173

# Jira Cloud integration
# Example: https://your-company.atlassian.net
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Optional OpenAI-compatible scenario enhancement.
# The app works without this; it falls back to deterministic local generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# API execution defaults
REQUEST_TIMEOUT_MS=20000
